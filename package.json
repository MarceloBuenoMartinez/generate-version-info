{
  "name": "generate-version-info",
  "version": "0.0.1",
  "description": "Generate version information files for different environments",
  "bin": {
    "generate-version-info": "dist/bin/cli.js"
  },
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "files": [
    "dist/",
    "config/"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm run build",
    "test": "echo 'No tests yet'"
  },
  "keywords": [
    "version",
    "versioning", 
    "deployment",
    "environment",
    "cli"
  ],
  "author": "Marcelo Bueno Martinez <marcelo.bueno.martinez@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/MarceloBuenoMartinez/generate-version-info.git"
  },
  "packageManager": "pnpm@10.12.1",
  "dependencies": {
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
